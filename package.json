{
  "name": "claude-code-notifier-plus",
  "displayName": "Claude Code Notifier Plus",
  "description": "Get notifications when Claude Code needs your attention — works in both CLI and VS Code extension mode",
  "version": "1.1.1",
  "publisher": "tutuge",
  "author": {
    "name": "tutuge"
  },
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zekunyan/claude-code-notifier-plus"
  },
  "homepage": "https://github.com/zekunyan/claude-code-notifier-plus#readme",
  "bugs": {
    "url": "https://github.com/zekunyan/claude-code-notifier-plus/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "notification",
    "notifier",
    "ai"
  ],
  "categories": [
    "AI",
    "Other"
  ],
  "galleryBanner": {
    "color": "#150D30",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "claude-notifier-plus.notify",
        "title": "%command.sendTestNotification%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "claudeCodeNotifierPlus.notifyOnPermissionRequest": {
          "type": "boolean",
          "default": true,
          "description": "%config.notifyOnPermissionRequest%"
        },
        "claudeCodeNotifierPlus.notifyOnQuestion": {
          "type": "boolean",
          "default": true,
          "description": "%config.notifyOnQuestion%"
        },
        "claudeCodeNotifierPlus.notifyOnTaskComplete": {
          "type": "boolean",
          "default": true,
          "description": "%config.notifyOnTaskComplete%"
        },
        "claudeCodeNotifierPlus.notifyOnSubagentStop": {
          "type": "boolean",
          "default": false,
          "description": "%config.notifyOnSubagentStop%"
        },
        "claudeCodeNotifierPlus.systemNotification": {
          "type": "boolean",
          "default": true,
          "description": "%config.systemNotification%"
        },
        "claudeCodeNotifierPlus.sound": {
          "type": "boolean",
          "default": false,
          "description": "%config.sound%"
        },
        "claudeCodeNotifierPlus.notificationDelay": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 60,
          "description": "%config.notificationDelay%"
        },
        "claudeCodeNotifierPlus.showVSCodePopup": {
          "type": "boolean",
          "default": false,
          "description": "%config.showVSCodePopup%"
        },
        "claudeCodeNotifierPlus.clickToFocus": {
          "type": "string",
          "default": "window",
          "enum": ["window", "app", "off"],
          "enumDescriptions": [
            "%config.clickToFocus.window%",
            "%config.clickToFocus.app%",
            "%config.clickToFocus.off%"
          ],
          "description": "%config.clickToFocus.description%"
        },
        "claudeCodeNotifierPlus.suppressWhenFocused": {
          "type": "boolean",
          "default": false,
          "description": "%config.suppressWhenFocused%"
        }
      }
    }
  }
}
